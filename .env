# Shovly environment configuration
# Generated by setup.sh on 2026-06-26 00:34:01
# Source this file or export each variable before running agent/server scripts.

# ── Slurm ────────────────────────────────────────────────────────────────────
SLURM_BIN_DIR="/cm/shared/apps/slurm/current/bin"
SLURM_CONF_DIR="/cm/shared/apps/slurm/current/etc"

# ── Dashboard server ─────────────────────────────────────────────────────────
# URL agents POST data to
DASHBOARD_URL="http://localhost:8000/api/agent/data"
# Hostname/IP the uvicorn server binds to (bare-metal mode only)
UVICORN_HOST="0.0.0.0"
UVICORN_PORT="8000"

# ── Agent ────────────────────────────────────────────────────────────────────
CLUSTER_NAME="slurm"
# Last-resort GPU model when job GRES and scontrol node map both lack model info.
# Leave blank for CPU-only clusters or clusters where users always specify model.
DEFAULT_GPU_MODEL=""

# ── Paths ────────────────────────────────────────────────────────────────────
APP_DIR="/Users/shanecorder/Devel/shovly/hpc-cost-comparator"
DATA_DIR="/Users/shanecorder/Devel/shovly/hpc-cost-comparator/data"
LOG_DIR="/Users/shanecorder/Devel/shovly/hpc-cost-comparator/logs"
DB_PATH="/Users/shanecorder/Devel/shovly/hpc-cost-comparator/data/historical.db"
