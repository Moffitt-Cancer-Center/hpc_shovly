# .env.example — Shovly environment variable reference
#
# Copy this file to .env and fill in values for your site:
#   cp .env.example .env
#
# Alternatively, run setup.sh which generates .env interactively:
#   bash setup.sh
#
# Variables marked [agent] are only needed on HPC login nodes running agent.py.
# Variables marked [server] are only needed on the dashboard server.
# Variables marked [both] are used by both.

# ── Slurm [agent] ────────────────────────────────────────────────────────────
# Full path to the directory containing squeue, scontrol, sacct, etc.
# Leave blank to use whatever is on $PATH.
SLURM_BIN_DIR="/cm/shared/apps/slurm/current/bin"

# Full path to the Slurm configuration directory (slurm.conf lives here).
SLURM_CONF_DIR="/cm/shared/apps/slurm/current/etc"

# ── Dashboard server [server] ─────────────────────────────────────────────────
# Hostname or IP the Uvicorn process binds to (bare-metal mode only).
# When running via Docker Compose this is set inside the container.
UVICORN_HOST="0.0.0.0"
UVICORN_PORT="8000"

# ── Agent endpoint [agent] ────────────────────────────────────────────────────
# Full URL of the agent data endpoint on the dashboard server.
# Use the server's hostname or IP that is reachable from the HPC login node.
DASHBOARD_URL="http://your-dashboard-server:8000/api/agent/data"

# ── Agent identity [agent] ────────────────────────────────────────────────────
# Human-readable name for this Slurm cluster shown in the dashboard.
CLUSTER_NAME="your-cluster-name"

# Fallback GPU model to report when a job requested GPUs via --gres=gpu:N
# (count only) without specifying the model (e.g. --gres=gpu:a30:N).
# Must match a key in GPU_MODEL_MAP in hpc-cost-comparator/load_pricelist.py.
# Leave blank for CPU-only clusters or when all jobs always specify the model.
DEFAULT_GPU_MODEL=""

# ── Paths [both] ──────────────────────────────────────────────────────────────
# These are generated by setup.sh using SCRIPT_DIR as the base.
# Override only if your layout differs from the defaults.
APP_DIR="/path/to/shovly"
DATA_DIR="/path/to/shovly/data"
LOG_DIR="/path/to/shovly/hpc-cost-comparator/logs"
DB_PATH="/path/to/shovly/data/historical.db"
